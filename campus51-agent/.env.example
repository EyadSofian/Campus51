# ============================================================
# Campus 51 — Murshid Agent | Environment Variables
# انسخ الملف ده باسم .env واملا القيم
#   cp .env.example .env
# ============================================================

# --- 1) مفتاح موديل Gemini ---
# هتجيبه من: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# اسم الموديل (بدون prefix، LangChain بيحدده تلقائياً)
LLM_MODEL=gemini-2.5-flash

# درجة الحرارة — البوت الأصلي على 0.3 (دقيق ومش بيهلوس)
LLM_TEMPERATURE=0.3

# --- 2) Pinecone (vector store سحابي للـ KB) ---
# هتجيبه من: https://app.pinecone.io/ → API Keys
PINECONE_API_KEY=your_pinecone_api_key_here
# اسم الـ index (بيتنشأ تلقائياً لو مش موجود)
PINECONE_INDEX_NAME=campus51-kb

# --- 3) Campus51 Lead Endpoint (نفس اللي في Execute Code في Botpress) ---
CAMPUS51_LEADS_ENDPOINT=https://campus51-auth-dot-plexiform-crane-421805.ey.r.appspot.com/api/chatbot-leads
CAMPUS51_API_KEY=ask_shehab_for_this_key

# --- 4) WhatsApp Cloud API (Meta) ---
# من Meta Developers → WhatsApp → API Setup
WHATSAPP_TOKEN=your_permanent_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
# توكن بتخترعه انت وتحطه في إعدادات الـ Webhook عند Meta (للتحقق)
WHATSAPP_VERIFY_TOKEN=campus51_murshid_verify_2026

# --- 5) مسارات محلية ---
KB_DIR=data/kb                 # مكان ملفات الـ Knowledge Base
